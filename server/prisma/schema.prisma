generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LogStatus {
  UNLOCKED
  LOCKED
}

model DailyLog {
  id          String    @id @default(uuid()) @unique()
  createdAt   DateTime  @map("created_at")
  status      LogStatus @default(UNLOCKED)
  lockedAt    DateTime? @map("locked_at")
  
  payload     Json      @map("metrics")

  unitId      String
  unit        Unit         @relation(fields: [unitId], references: [id])
  
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id])

  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([unitId, createdAt])
  @@map("daily_logs")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  ORG_STAFF
  UNIT_OPERATOR
}

model Organization {
  id     String             @id @default(uuid())
  name   String
  status String             @default("INACTIVE")
  units  Unit[]
  users User[]
  logs  DailyLog[]
}

model Unit {
  id    String             @id @default(uuid())
  name  String
  orgId String
  org   Organization       @relation(fields: [orgId], references: [id])
  users User[]
  logs  DailyLog[]

  @@unique([name, orgId])
}

model User {
  id       String        @id @default(uuid())
  name     String?
  email    String        @unique
  password String?
  status   String        @default("INACTIVE")
  role     Role
  orgId    String?
  org      Organization? @relation(fields: [orgId], references: [id])
  unitId   String?
  unit     Unit?         @relation(fields: [unitId], references: [id])
}

model InviteToken {
  id          String   @id @default(uuid())
  tokenString String   @unique
  email       String
  role        Role
  orgId       String
  unitId      String?
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
}