generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model DailyAnalysisLog {
  id          String    @id @default(uuid()) @unique()
  
  logDate     DateTime   @unique @map("log_date")
  
  metrics     Json

  unitId      String
  unit        Unit         @relation(fields: [unitId], references: [id])
  
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id])

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("daily_analysis_logs")
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  ORG_STAFF
  UNIT_OPERATOR
}

model Organization {
  id     String             @id @default(uuid())
  name   String
  status String             @default("INACTIVE")
  units  Unit[]
  users User[]
  logs  DailyAnalysisLog[]
}

model Unit {
  id    String             @id @default(uuid())
  name  String
  orgId String
  org   Organization       @relation(fields: [orgId], references: [id])
  users User[]
  logs  DailyAnalysisLog[]
}

model User {
  id       String        @id @default(uuid())
  name     String?
  email    String        @unique
  password String?
  status   String        @default("INACTIVE")
  role     Role
  orgId    String?
  org      Organization? @relation(fields: [orgId], references: [id])
  unitId   String?
  unit     Unit?         @relation(fields: [unitId], references: [id])
}

model InviteToken {
  id          String   @id @default(uuid())
  tokenString String   @unique
  email       String
  role        Role
  orgId       String
  unitId      String?
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
}